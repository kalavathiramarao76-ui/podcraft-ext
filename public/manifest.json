{
  "manifest_version": 3,
  "name": "PodCraft AI",
  "version": "1.0.0",
  "description": "Repurpose podcast episodes into summaries, clips, LinkedIn posts, Twitter threads, newsletters, and show notes.",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "host_permissions": ["https://sai.sharedllm.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://open.spotify.com/*"
      ],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
